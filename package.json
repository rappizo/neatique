{
  "name": "neatique-beauty",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx scripts/sync-comic-reference-assets.ts && next dev",
    "build": "tsx scripts/sync-comic-reference-assets.ts && next build && tsx scripts/check-next-function-traces.ts",
    "vercel-build": "prisma generate && prisma migrate deploy && tsx scripts/sync-comic-reference-assets.ts && next build && tsx scripts/check-next-function-traces.ts",
    "start": "next start",
    "test": "tsx --test tests/*.test.ts",
    "lint": "next lint",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:status": "prisma migrate status",
    "db:seed": "node prisma/seed.js",
    "db:studio": "prisma studio",
    "comic:sync": "tsx scripts/sync-comic-workspace.ts",
    "comic:compress-references": "tsx scripts/compress-comic-reference-assets.ts && tsx scripts/sync-comic-reference-assets.ts",
    "comic:references": "tsx scripts/sync-comic-reference-assets.ts",
    "comic:migrate-images": "tsx scripts/migrate-comic-images-to-blob.ts",
    "media:migrate-blob": "tsx scripts/migrate-site-media-to-blob.ts",
    "stripe:listen": "stripe listen --forward-to localhost:3000/api/stripe/webhook",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "@vercel/blob": "2.6.1",
    "imapflow": "1.4.7",
    "mailparser": "3.9.14",
    "next": "15.5.20",
    "nodemailer": "9.0.3",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "sharp": "^0.34.5",
    "stripe": "^18.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "15.5.20",
    "prisma": "6.19.3",
    "tsx": "4.23.1",
    "typescript": "^5.0.0"
  },
  "overrides": {
    "postcss": "8.5.19",
    "qs": "6.15.3",
    "undici": "6.27.0"
  }
}
