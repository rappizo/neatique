generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ProductStatus {
  ACTIVE
  DRAFT
  ARCHIVED
}

enum OrderStatus {
  PENDING
  PAID
  FULFILLED
  CANCELLED
  REFUNDED
}

enum FulfillmentStatus {
  UNFULFILLED
  PROCESSING
  SHIPPED
  DELIVERED
}

enum RewardType {
  EARNED
  REDEEMED
  ADJUSTMENT
}

enum MascotRedemptionStatus {
  REQUESTED
  FULFILLED
  CANCELLED
}

enum ReviewStatus {
  PENDING
  PUBLISHED
  HIDDEN
}

enum CouponDiscountType {
  PERCENT
  FIXED_AMOUNT
}

enum CouponUsageMode {
  SINGLE_USE
  UNLIMITED
}

enum EmailCampaignStatus {
  DRAFT
  SYNCED
  SCHEDULED
  SENT
  FAILED
}

enum EmailAudienceType {
  NEWSLETTER
  CUSTOMERS
  LEADS
  ALL_MARKETING
  CUSTOM
}

enum FollowEmailProcess {
  OMB
  RYO
}

enum FollowEmailStage {
  WAITING_STEP_2
  WAITING_LAST_STEP
  COMPLETED
}

enum ComicPromptRunStatus {
  DRAFT
  READY
  FAILED
  APPROVED
}

model Product {
  id                  String        @id @default(cuid())
  productCode         String?       @unique
  productShortName    String?
  amazonAsin          String?
  name                String
  slug                String        @unique
  tagline             String
  category            String
  shortDescription    String
  description         String
  details             String
  imageUrl            String
  galleryImages       String?
  featured            Boolean       @default(false)
  status              ProductStatus @default(DRAFT)
  inventory           Int           @default(0)
  priceCents          Int
  compareAtPriceCents Int?
  currency            String        @default("USD")
  pointsReward        Int           @default(0)
  stripePriceId       String?
  orderItems          OrderItem[]
  reviews             ProductReview[]
  posts               Post[]
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@index([status, featured, createdAt])
}

model Post {
  id             String   @id @default(cuid())
  title          String
  slug           String   @unique
  excerpt        String
  category       String
  readTime       Int      @default(4)
  coverImageUrl  String
  coverImageAlt  String?
  coverImageData String?
  coverImageMimeType String?
  previewImageData String?
  previewImageMimeType String?
  previewImagePrompt String?
  previewImageGeneratedAt DateTime?
  content        String
  seoTitle       String
  seoDescription String
  aiGenerated    Boolean  @default(false)
  focusKeyword   String?
  secondaryKeywords String?
  imagePrompt    String?
  externalLinks  String?
  generatedAt    DateTime?
  sourceProductId String?
  published      Boolean  @default(false)
  publishedAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  sourceProduct  Product? @relation(fields: [sourceProductId], references: [id], onDelete: SetNull)

  @@index([published, publishedAt])
  @@index([aiGenerated, createdAt])
  @@index([sourceProductId, createdAt])
}

model ComicProject {
  id               String           @id @default(cuid())
  slug             String           @unique
  title            String
  shortDescription String
  storyOutline     String
  worldRules       String
  visualStyleGuide String
  workflowNotes    String?
  characters       ComicCharacter[]
  scenes           ComicScene[]
  seasons          ComicSeason[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model ComicCharacter {
  id              String       @id @default(cuid())
  name            String
  chineseName     String?
  slug            String       @unique
  role            String
  appearance      String
  personality     String
  speechGuide     String
  referenceFolder String
  referenceNotes  String?
  active          Boolean      @default(true)
  sortOrder       Int          @default(0)
  projectId       String
  project         ComicProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([projectId, sortOrder, createdAt])
  @@index([active, sortOrder])
}

model ComicScene {
  id              String       @id @default(cuid())
  name            String
  slug            String       @unique
  summary         String
  visualNotes     String
  moodNotes       String
  referenceFolder String
  referenceNotes  String?
  active          Boolean      @default(true)
  sortOrder       Int          @default(0)
  projectId       String
  project         ComicProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([projectId, sortOrder, createdAt])
  @@index([active, sortOrder])
}

model ComicSeason {
  id         String         @id @default(cuid())
  seasonNumber Int
  slug       String
  title      String
  summary    String
  outline    String
  published  Boolean        @default(false)
  sortOrder  Int            @default(0)
  projectId  String
  project    ComicProject   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  chapters   ComicChapter[]
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@unique([projectId, seasonNumber])
  @@unique([projectId, slug])
  @@index([published, sortOrder, createdAt])
}

model ComicChapter {
  id            String         @id @default(cuid())
  chapterNumber Int
  slug          String
  title         String
  summary       String
  outline       String
  published     Boolean        @default(false)
  sortOrder     Int            @default(0)
  seasonId      String
  season        ComicSeason    @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  episodes      ComicEpisode[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([seasonId, chapterNumber])
  @@unique([seasonId, slug])
  @@index([published, sortOrder, createdAt])
}

model ComicEpisode {
  id                 String            @id @default(cuid())
  episodeNumber      Int
  slug               String
  title              String
  summary            String
  outline            String
  script             String
  panelPlan          String
  promptPack         String
  requiredReferences String
  coverImageUrl      String?
  coverImageAlt      String?
  published          Boolean           @default(false)
  publishedAt        DateTime?
  sortOrder          Int               @default(0)
  chapterId          String
  chapter            ComicChapter      @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  assets             ComicEpisodeAsset[]
  promptRuns         ComicPromptRun[]
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@unique([chapterId, episodeNumber])
  @@unique([chapterId, slug])
  @@index([published, publishedAt, sortOrder, createdAt])
}

model ComicEpisodeAsset {
  id        String       @id @default(cuid())
  assetType String       @default("PAGE")
  title     String
  imageUrl  String
  imageData String?
  imageMimeType String?
  imageStorageKey String?
  imageByteSize Int?
  imageSha256 String?
  altText   String?
  caption   String?
  sortOrder Int          @default(0)
  published Boolean      @default(true)
  episodeId String
  episode   ComicEpisode @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([episodeId, published, sortOrder, createdAt])
}

model ComicPromptRun {
  id                 String              @id @default(cuid())
  promptType         String
  model              String
  imageModel         String?
  status             ComicPromptRunStatus @default(DRAFT)
  inputContext       String
  outputSummary      String
  promptPack         String?
  referenceChecklist String?
  errorMessage       String?
  episodeId          String
  episode            ComicEpisode        @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([episodeId, createdAt])
  @@index([status, createdAt])
}

model ComicAiTask {
  id            String   @id @default(cuid())
  taskType      String
  label         String
  status        String   @default("QUEUED")
  payload       String
  result        String?
  errorMessage  String?
  episodeId     String?
  pageNumber    Int?
  targetId      String?
  sourceAssetId String?
  attempts      Int      @default(0)
  maxAttempts   Int      @default(2)
  lockedAt      DateTime?
  completedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status, createdAt])
  @@index([episodeId, pageNumber, createdAt])
  @@index([taskType, targetId, status, createdAt])
  @@index([sourceAssetId, status, createdAt])
}

model ComicImageCreation {
  id              String   @id @default(cuid())
  prompt          String
  aspectRatio     String
  model           String
  imageUrl        String
  imageData       String?
  imageMimeType   String?
  imageStorageKey String?
  imageByteSize   Int?
  imageSha256     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([createdAt])
}

model Customer {
  id              String        @id @default(cuid())
  email           String        @unique
  firstName       String?
  lastName        String?
  passwordHash    String?
  passwordSetAt   DateTime?
  lastLoginAt     DateTime?
  marketingOptIn  Boolean       @default(false)
  loyaltyPoints   Int           @default(0)
  totalSpentCents Int           @default(0)
  orders          Order[]
  rewards         RewardEntry[]
  mascotRedemptions MascotRedemption[]
  ryoClaims       RyoClaim[]
  reviews         ProductReview[]
  sessions        CustomerSession[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model MascotReward {
  id          String             @id @default(cuid())
  sku         String             @unique
  name        String
  slug        String             @unique
  description String?
  imageUrl    String
  pointsCost  Int                @default(1000)
  active      Boolean            @default(true)
  sortOrder   Int                @default(0)
  redemptions MascotRedemption[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

model MascotRedemption {
  id          String                 @id @default(cuid())
  pointsSpent Int
  status      MascotRedemptionStatus @default(REQUESTED)
  email       String
  fullName    String
  address1    String
  address2    String?
  city        String
  state       String
  postalCode  String
  country     String                @default("US")
  adminNote   String?
  fulfilledAt DateTime?
  customerId  String
  mascotId    String
  customer    Customer              @relation(fields: [customerId], references: [id], onDelete: Cascade)
  mascot      MascotReward          @relation(fields: [mascotId], references: [id], onDelete: Cascade)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@index([customerId, createdAt])
  @@index([status, createdAt])
}

model EmailContact {
  id               String            @id @default(cuid())
  email            String
  firstName        String?
  lastName         String?
  audienceType     EmailAudienceType
  source           String            @default("BREVO_IMPORT")
  brevoContactId   Int?
  brevoListId      Int?
  listName         String?
  emailBlacklisted Boolean           @default(false)
  metadata         String?
  lastSyncedAt     DateTime          @default(now())
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@unique([email, audienceType])
  @@index([audienceType, updatedAt])
  @@index([brevoListId])
}

model Order {
  id                    String            @id @default(cuid())
  orderNumber           String            @unique
  email                 String
  status                OrderStatus       @default(PENDING)
  fulfillmentStatus     FulfillmentStatus @default(UNFULFILLED)
  currency              String            @default("USD")
  subtotalCents         Int
  discountCents         Int               @default(0)
  shippingCents         Int               @default(0)
  taxCents              Int               @default(0)
  totalCents            Int
  pointsEarned          Int               @default(0)
  couponCode            String?
  couponId              String?
  stripeCheckoutId      String?           @unique
  stripePaymentIntentId String?
  shippingName          String?
  shippingAddress1      String?
  shippingAddress2      String?
  shippingCity          String?
  shippingState         String?
  shippingPostalCode    String?
  shippingCountry       String?
  billingName           String?
  billingAddress1       String?
  billingAddress2       String?
  billingCity           String?
  billingState          String?
  billingPostalCode     String?
  billingCountry        String?
  notes                 String?
  customerId            String?
  customer              Customer?         @relation(fields: [customerId], references: [id])
  coupon                Coupon?           @relation(fields: [couponId], references: [id], onDelete: SetNull)
  items                 OrderItem[]
  activityLogs          OrderActivityLog[]
  rewards               RewardEntry[]
  reviews               ProductReview[]
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  @@index([createdAt])
  @@index([status, createdAt])
  @@index([customerId, createdAt])
}

model OrderActivityLog {
  id        String   @id @default(cuid())
  eventType String
  summary   String
  detail    String?
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([orderId, createdAt])
  @@index([eventType, createdAt])
}

model OrderItem {
  id             String   @id @default(cuid())
  name           String
  slug           String
  quantity       Int
  unitPriceCents Int
  lineTotalCents Int
  imageUrl       String
  orderId        String
  productId      String?
  order          Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product        Product? @relation(fields: [productId], references: [id])
}

model RewardEntry {
  id         String     @id @default(cuid())
  type       RewardType
  points     Int
  note       String?
  customerId String
  orderId    String?
  customer   Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  order      Order?     @relation(fields: [orderId], references: [id])
  createdAt  DateTime   @default(now())

  @@index([customerId, createdAt])
  @@index([type, createdAt])
}

model RyoClaim {
  id                   String    @id @default(cuid())
  platformKey          String
  platformLabel        String
  orderId              String
  name                 String
  email                String
  phone                String?
  purchasedProduct     String?
  reviewRating         Int?
  commentText          String?
  reviewDestinationUrl String?
  screenshotName       String?
  screenshotMimeType   String?
  screenshotBase64     String?
  screenshotBytes      Int?
  customerId           String?
  pointsAwarded        Int       @default(500)
  rewardGranted        Boolean   @default(false)
  rewardGrantedAt      DateTime?
  reviewStepSubmittedAt DateTime?
  adminNote            String?
  completedAt          DateTime?
  customer             Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  followEmails         FollowEmailLog[]
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([platformKey, createdAt])
  @@index([email, createdAt])
  @@index([completedAt, createdAt])
  @@index([rewardGranted])
}

model CustomerSession {
  id         String   @id @default(cuid())
  tokenHash  String   @unique
  expiresAt  DateTime
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model ProductReview {
  id               String       @id @default(cuid())
  rating           Int
  title            String
  content          String
  displayName      String
  reviewDate       DateTime     @default(now())
  status           ReviewStatus @default(PENDING)
  verifiedPurchase Boolean      @default(false)
  adminNotes       String?
  source           String       @default("CUSTOMER")
  productId        String
  customerId       String?
  orderId          String?
  publishedAt      DateTime?
  product          Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  customer         Customer?    @relation(fields: [customerId], references: [id], onDelete: SetNull)
  order            Order?       @relation(fields: [orderId], references: [id], onDelete: SetNull)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([productId, reviewDate])
  @@index([productId, status, reviewDate])
  @@index([customerId, reviewDate])
  @@index([status, reviewDate])
}

model StoreSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  createdAt DateTime @default(now())
}

model Coupon {
  id             String             @id @default(cuid())
  code           String             @unique
  content        String
  active         Boolean            @default(true)
  combinable     Boolean            @default(false)
  appliesToAll   Boolean            @default(false)
  productCodes   String?
  discountType   CouponDiscountType
  percentOff     Int?
  amountOffCents Int?
  usageMode      CouponUsageMode    @default(UNLIMITED)
  usageCount     Int                @default(0)
  expiresAt      DateTime?
  orders         Order[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([active, expiresAt])
}

model FormSubmission {
  id                        String   @id @default(cuid())
  formKey                   String
  formLabel                 String
  email                     String
  name                      String?
  subject                   String?
  summary                   String?
  message                   String?
  payload                   String?
  handled                   Boolean  @default(false)
  handledAt                 DateTime?
  legacyContactSubmissionId String?  @unique
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  @@index([formKey, createdAt])
  @@index([formKey, handled, createdAt])
  @@index([formKey, email, createdAt])
  @@index([email])
  @@index([handled])
}

model EmailCampaign {
  id              String              @id @default(cuid())
  name            String
  subject         String
  previewText     String?
  strategyBrief   String?
  audienceType    EmailAudienceType   @default(NEWSLETTER)
  customListIds   String?
  senderName      String?
  senderEmail     String?
  replyTo         String?
  contentHtml     String
  contentText     String?
  scheduledAt     DateTime?
  status          EmailCampaignStatus @default(DRAFT)
  brevoCampaignId Int?
  lastSyncedAt    DateTime?
  lastTestedAt    DateTime?
  lastSentAt      DateTime?
  syncError       String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([status, updatedAt])
  @@index([audienceType])
  @@index([scheduledAt])
}

model OmbClaim {
  id                   String   @id @default(cuid())
  platformKey          String
  platformLabel        String
  orderId              String
  name                 String
  email                String
  phone                String?
  purchasedProduct     String?
  reviewRating         Int?
  commentText          String?
  reviewDestinationUrl String?
  screenshotName       String?
  screenshotMimeType   String?
  screenshotBase64     String?
  screenshotBytes      Int?
  extraBottleAddress   String?
  giftSent             Boolean  @default(false)
  giftSentAt           DateTime?
  reviewStepSubmittedAt DateTime?
  adminNote            String?
  completedAt          DateTime?
  followEmails         FollowEmailLog[]
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([platformKey, createdAt])
  @@index([email, createdAt])
  @@index([platformKey, purchasedProduct, createdAt])
  @@index([giftSent])
  @@index([completedAt, createdAt])
}

model FollowEmailLog {
  id             String             @id @default(cuid())
  processKey     FollowEmailProcess
  stageKey       FollowEmailStage
  recipientEmail String
  recipientName  String?
  subject        String
  bodyText       String
  ombClaimId     String?
  ryoClaimId     String?
  ombClaim       OmbClaim?          @relation(fields: [ombClaimId], references: [id], onDelete: Cascade)
  ryoClaim       RyoClaim?          @relation(fields: [ryoClaimId], references: [id], onDelete: Cascade)
  createdAt      DateTime           @default(now())

  @@unique([ombClaimId, stageKey])
  @@unique([ryoClaimId, stageKey])
  @@index([processKey, createdAt])
  @@index([stageKey, createdAt])
}

model MailboxReplyExample {
  id                String   @id @default(cuid())
  toEmail           String
  subject           String
  bodyText          String
  replyTo           String?
  sourceSenderName  String?
  sourceSenderEmail String?
  sourceSubject     String?
  sourceSnippet     String?
  createdAt         DateTime @default(now())

  @@index([toEmail, createdAt])
  @@index([createdAt])
}
