generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ProductStatus {
  ACTIVE
  DRAFT
  ARCHIVED
}

enum OrderStatus {
  PENDING
  PAID
  FULFILLED
  CANCELLED
  REFUNDED
}

enum FulfillmentStatus {
  UNFULFILLED
  PROCESSING
  SHIPPED
  DELIVERED
}

enum RewardType {
  EARNED
  REDEEMED
  ADJUSTMENT
}

enum MascotRedemptionStatus {
  REQUESTED
  FULFILLED
  CANCELLED
}

enum ReviewStatus {
  PENDING
  PUBLISHED
  HIDDEN
}

enum CouponDiscountType {
  PERCENT
  FIXED_AMOUNT
}

enum CouponUsageMode {
  SINGLE_USE
  UNLIMITED
}

enum EmailCampaignStatus {
  DRAFT
  SYNCED
  SCHEDULED
  SENT
  FAILED
}

enum EmailAudienceType {
  NEWSLETTER
  CUSTOMERS
  LEADS
  ALL_MARKETING
  CUSTOM
}

enum FollowEmailProcess {
  OMB
  RYO
}

enum FollowEmailStage {
  WAITING_STEP_2
  WAITING_LAST_STEP
  COMPLETED
}

model Product {
  id                  String        @id @default(cuid())
  productCode         String?       @unique
  productShortName    String?
  amazonAsin          String?
  name                String
  slug                String        @unique
  tagline             String
  category            String
  shortDescription    String
  description         String
  details             String
  imageUrl            String
  galleryImages       String?
  featured            Boolean       @default(false)
  status              ProductStatus @default(DRAFT)
  inventory           Int           @default(0)
  priceCents          Int
  compareAtPriceCents Int?
  currency            String        @default("USD")
  pointsReward        Int           @default(0)
  stripePriceId       String?
  orderItems          OrderItem[]
  reviews             ProductReview[]
  posts               Post[]
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
}

model Post {
  id             String   @id @default(cuid())
  title          String
  slug           String   @unique
  excerpt        String
  category       String
  readTime       Int      @default(4)
  coverImageUrl  String
  coverImageAlt  String?
  coverImageData String?
  coverImageMimeType String?
  previewImageData String?
  previewImageMimeType String?
  previewImagePrompt String?
  previewImageGeneratedAt DateTime?
  content        String
  seoTitle       String
  seoDescription String
  aiGenerated    Boolean  @default(false)
  focusKeyword   String?
  secondaryKeywords String?
  imagePrompt    String?
  externalLinks  String?
  generatedAt    DateTime?
  sourceProductId String?
  published      Boolean  @default(false)
  publishedAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  sourceProduct  Product? @relation(fields: [sourceProductId], references: [id], onDelete: SetNull)

  @@index([published, publishedAt])
  @@index([aiGenerated, createdAt])
  @@index([sourceProductId, createdAt])
}

model Customer {
  id              String        @id @default(cuid())
  email           String        @unique
  firstName       String?
  lastName        String?
  passwordHash    String?
  passwordSetAt   DateTime?
  lastLoginAt     DateTime?
  marketingOptIn  Boolean       @default(false)
  loyaltyPoints   Int           @default(0)
  totalSpentCents Int           @default(0)
  orders          Order[]
  rewards         RewardEntry[]
  mascotRedemptions MascotRedemption[]
  ryoClaims       RyoClaim[]
  reviews         ProductReview[]
  sessions        CustomerSession[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model MascotReward {
  id          String             @id @default(cuid())
  sku         String             @unique
  name        String
  slug        String             @unique
  description String?
  imageUrl    String
  pointsCost  Int                @default(1000)
  active      Boolean            @default(true)
  sortOrder   Int                @default(0)
  redemptions MascotRedemption[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

model MascotRedemption {
  id          String                 @id @default(cuid())
  pointsSpent Int
  status      MascotRedemptionStatus @default(REQUESTED)
  email       String
  fullName    String
  address1    String
  address2    String?
  city        String
  state       String
  postalCode  String
  country     String                @default("US")
  adminNote   String?
  fulfilledAt DateTime?
  customerId  String
  mascotId    String
  customer    Customer              @relation(fields: [customerId], references: [id], onDelete: Cascade)
  mascot      MascotReward          @relation(fields: [mascotId], references: [id], onDelete: Cascade)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@index([customerId, createdAt])
  @@index([status, createdAt])
}

model EmailContact {
  id               String            @id @default(cuid())
  email            String
  firstName        String?
  lastName         String?
  audienceType     EmailAudienceType
  source           String            @default("BREVO_IMPORT")
  brevoContactId   Int?
  brevoListId      Int?
  listName         String?
  emailBlacklisted Boolean           @default(false)
  metadata         String?
  lastSyncedAt     DateTime          @default(now())
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@unique([email, audienceType])
  @@index([audienceType, updatedAt])
  @@index([brevoListId])
}

model Order {
  id                    String            @id @default(cuid())
  orderNumber           String            @unique
  email                 String
  status                OrderStatus       @default(PENDING)
  fulfillmentStatus     FulfillmentStatus @default(UNFULFILLED)
  currency              String            @default("USD")
  subtotalCents         Int
  discountCents         Int               @default(0)
  shippingCents         Int               @default(0)
  taxCents              Int               @default(0)
  totalCents            Int
  pointsEarned          Int               @default(0)
  couponCode            String?
  couponId              String?
  stripeCheckoutId      String?
  stripePaymentIntentId String?
  shippingName          String?
  shippingAddress1      String?
  shippingAddress2      String?
  shippingCity          String?
  shippingState         String?
  shippingPostalCode    String?
  shippingCountry       String?
  billingName           String?
  billingAddress1       String?
  billingAddress2       String?
  billingCity           String?
  billingState          String?
  billingPostalCode     String?
  billingCountry        String?
  notes                 String?
  customerId            String?
  customer              Customer?         @relation(fields: [customerId], references: [id])
  coupon                Coupon?           @relation(fields: [couponId], references: [id], onDelete: SetNull)
  items                 OrderItem[]
  rewards               RewardEntry[]
  reviews               ProductReview[]
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
}

model OrderItem {
  id             String   @id @default(cuid())
  name           String
  slug           String
  quantity       Int
  unitPriceCents Int
  lineTotalCents Int
  imageUrl       String
  orderId        String
  productId      String?
  order          Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product        Product? @relation(fields: [productId], references: [id])
}

model RewardEntry {
  id         String     @id @default(cuid())
  type       RewardType
  points     Int
  note       String?
  customerId String
  orderId    String?
  customer   Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  order      Order?     @relation(fields: [orderId], references: [id])
  createdAt  DateTime   @default(now())
}

model RyoClaim {
  id                   String    @id @default(cuid())
  platformKey          String
  platformLabel        String
  orderId              String
  name                 String
  email                String
  phone                String?
  purchasedProduct     String?
  reviewRating         Int?
  commentText          String?
  reviewDestinationUrl String?
  screenshotName       String?
  screenshotMimeType   String?
  screenshotBase64     String?
  screenshotBytes      Int?
  customerId           String?
  pointsAwarded        Int       @default(500)
  rewardGranted        Boolean   @default(false)
  rewardGrantedAt      DateTime?
  reviewStepSubmittedAt DateTime?
  adminNote            String?
  completedAt          DateTime?
  customer             Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  followEmails         FollowEmailLog[]
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([platformKey, createdAt])
  @@index([email])
  @@index([completedAt])
  @@index([rewardGranted])
}

model CustomerSession {
  id         String   @id @default(cuid())
  tokenHash  String   @unique
  expiresAt  DateTime
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model ProductReview {
  id               String       @id @default(cuid())
  rating           Int
  title            String
  content          String
  displayName      String
  reviewDate       DateTime     @default(now())
  status           ReviewStatus @default(PENDING)
  verifiedPurchase Boolean      @default(false)
  adminNotes       String?
  source           String       @default("CUSTOMER")
  productId        String
  customerId       String?
  orderId          String?
  publishedAt      DateTime?
  product          Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  customer         Customer?    @relation(fields: [customerId], references: [id], onDelete: SetNull)
  order            Order?       @relation(fields: [orderId], references: [id], onDelete: SetNull)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model StoreSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  createdAt DateTime @default(now())
}

model Coupon {
  id             String             @id @default(cuid())
  code           String             @unique
  content        String
  active         Boolean            @default(true)
  combinable     Boolean            @default(false)
  appliesToAll   Boolean            @default(false)
  productCodes   String?
  discountType   CouponDiscountType
  percentOff     Int?
  amountOffCents Int?
  usageMode      CouponUsageMode    @default(UNLIMITED)
  usageCount     Int                @default(0)
  expiresAt      DateTime?
  orders         Order[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
}

model FormSubmission {
  id                        String   @id @default(cuid())
  formKey                   String
  formLabel                 String
  email                     String
  name                      String?
  subject                   String?
  summary                   String?
  message                   String?
  payload                   String?
  handled                   Boolean  @default(false)
  handledAt                 DateTime?
  legacyContactSubmissionId String?  @unique
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  @@index([formKey, createdAt])
  @@index([email])
  @@index([handled])
}

model EmailCampaign {
  id              String              @id @default(cuid())
  name            String
  subject         String
  previewText     String?
  strategyBrief   String?
  audienceType    EmailAudienceType   @default(NEWSLETTER)
  customListIds   String?
  senderName      String?
  senderEmail     String?
  replyTo         String?
  contentHtml     String
  contentText     String?
  scheduledAt     DateTime?
  status          EmailCampaignStatus @default(DRAFT)
  brevoCampaignId Int?
  lastSyncedAt    DateTime?
  lastTestedAt    DateTime?
  lastSentAt      DateTime?
  syncError       String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([status, updatedAt])
  @@index([audienceType])
  @@index([scheduledAt])
}

model OmbClaim {
  id                   String   @id @default(cuid())
  platformKey          String
  platformLabel        String
  orderId              String
  name                 String
  email                String
  phone                String?
  purchasedProduct     String?
  reviewRating         Int?
  commentText          String?
  reviewDestinationUrl String?
  screenshotName       String?
  screenshotMimeType   String?
  screenshotBase64     String?
  screenshotBytes      Int?
  extraBottleAddress   String?
  giftSent             Boolean  @default(false)
  giftSentAt           DateTime?
  reviewStepSubmittedAt DateTime?
  adminNote            String?
  completedAt          DateTime?
  followEmails         FollowEmailLog[]
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([platformKey, createdAt])
  @@index([email])
  @@index([giftSent])
  @@index([completedAt])
}

model FollowEmailLog {
  id             String             @id @default(cuid())
  processKey     FollowEmailProcess
  stageKey       FollowEmailStage
  recipientEmail String
  recipientName  String?
  subject        String
  bodyText       String
  ombClaimId     String?
  ryoClaimId     String?
  ombClaim       OmbClaim?          @relation(fields: [ombClaimId], references: [id], onDelete: Cascade)
  ryoClaim       RyoClaim?          @relation(fields: [ryoClaimId], references: [id], onDelete: Cascade)
  createdAt      DateTime           @default(now())

  @@unique([ombClaimId, stageKey])
  @@unique([ryoClaimId, stageKey])
  @@index([processKey, createdAt])
  @@index([stageKey, createdAt])
}

model MailboxReplyExample {
  id                String   @id @default(cuid())
  toEmail           String
  subject           String
  bodyText          String
  replyTo           String?
  sourceSenderName  String?
  sourceSenderEmail String?
  sourceSubject     String?
  sourceSnippet     String?
  createdAt         DateTime @default(now())

  @@index([toEmail, createdAt])
  @@index([createdAt])
}
