generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ProductStatus {
  ACTIVE
  DRAFT
  ARCHIVED
}

enum OrderStatus {
  PENDING
  PAID
  FULFILLED
  CANCELLED
  REFUNDED
}

enum FulfillmentStatus {
  UNFULFILLED
  PROCESSING
  SHIPPED
  DELIVERED
}

enum ShippingCarrier {
  USPS
  UPS_GROUND
  DHL
  AMAZON_TBA
  GOFO
}

enum RewardType {
  EARNED
  REDEEMED
  ADJUSTMENT
}

enum MascotRedemptionStatus {
  REQUESTED
  FULFILLED
  CANCELLED
}

enum ReviewStatus {
  PENDING
  PUBLISHED
  HIDDEN
}

enum CouponDiscountType {
  PERCENT
  FIXED_AMOUNT
}

enum CouponUsageMode {
  SINGLE_USE
  UNLIMITED
}

enum EmailCampaignStatus {
  DRAFT
  SYNCED
  SCHEDULED
  SENT
  FAILED
}

enum EmailAudienceType {
  NEWSLETTER
  CUSTOMERS
  LEADS
  ALL_MARKETING
  CUSTOM
}

enum FollowEmailProcess {
  OMB
  RYO
}

enum FollowEmailStage {
  WAITING_STEP_2
  WAITING_LAST_STEP
  COMPLETED
}

enum ComicPromptRunStatus {
  DRAFT
  READY
  FAILED
  APPROVED
}

enum GuestRewardSessionStatus {
  ACTIVE
  CONVERTED
  EXPIRED
}

enum GuestRewardEventStatus {
  EARNED
  TRANSFERRED
  REVERSED
}

enum GuestRewardSource {
  RYO
  TIKTOK_FOLLOW
}

enum GuestRedemptionDraftStatus {
  PENDING_VERIFICATION
  COMPLETED
  EXPIRED
  CANCELLED
}

enum EmailVerificationPurpose {
  MASCOT_REDEMPTION
}

model Product {
  id                   String            @id @default(cuid())
  productCode          String?           @unique
  productShortName     String?
  amazonAsin           String?
  gtin                 String?
  mpn                  String?
  identifierExists     Boolean?
  name                 String
  slug                 String            @unique
  tagline              String
  category             String
  shortDescription     String
  description          String
  details              String
  netContent           String?
  ingredients          String?
  directions           String?
  warnings             String?
  countryOfOrigin      String?
  keyIngredientDetails String?
  pdrnSource           String?
  suitableFor          String?
  cautionFor           String?
  batchExpiryInfo      String?
  textureVideoUrl      String?
  seoTitle             String?
  seoDescription       String?
  priceValidUntil      DateTime?
  imageUrl             String
  galleryImages        String?
  featured             Boolean           @default(false)
  status               ProductStatus     @default(DRAFT)
  inventory            Int               @default(0)
  priceCents           Int
  compareAtPriceCents  Int?
  currency             String            @default("USD")
  pointsReward         Int               @default(0)
  stripePriceId        String?
  orderItems           OrderItem[]
  reviews              ProductReview[]
  posts                Post[]
  comicProductLock     ComicProductLock?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  @@index([status, featured, createdAt])
}

model Post {
  id                      String    @id @default(cuid())
  title                   String
  slug                    String    @unique
  excerpt                 String
  category                String
  readTime                Int       @default(4)
  coverImageUrl           String
  coverImageAlt           String?
  coverImageData          String?
  coverImageMimeType      String?
  previewImageData        String?
  previewImageMimeType    String?
  previewImagePrompt      String?
  previewImageGeneratedAt DateTime?
  content                 String
  seoTitle                String
  seoDescription          String
  aiGenerated             Boolean   @default(false)
  authorName              String?
  authorType              String?
  authorUrl               String?
  reviewerName            String?
  reviewerUrl             String?
  editorialReviewed       Boolean   @default(false)
  reviewedAt              DateTime?
  focusKeyword            String?
  secondaryKeywords       String?
  imagePrompt             String?
  externalLinks           String?
  generatedAt             DateTime?
  sourceProductId         String?
  published               Boolean   @default(false)
  publishedAt             DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  sourceProduct Product? @relation(fields: [sourceProductId], references: [id], onDelete: SetNull)

  @@index([published, publishedAt])
  @@index([aiGenerated, createdAt])
  @@index([sourceProductId, createdAt])
}

model ComicProject {
  id               String           @id @default(cuid())
  slug             String           @unique
  title            String
  shortDescription String
  storyOutline     String
  worldRules       String
  visualStyleGuide String
  workflowNotes    String?
  characters       ComicCharacter[]
  scenes           ComicScene[]
  seasons          ComicSeason[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model ComicCharacter {
  id              String       @id @default(cuid())
  name            String
  chineseName     String?
  slug            String       @unique
  role            String
  appearance      String
  personality     String
  speechGuide     String
  referenceFolder String
  referenceNotes  String?
  active          Boolean      @default(true)
  sortOrder       Int          @default(0)
  projectId       String
  project         ComicProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([projectId, sortOrder, createdAt])
  @@index([active, sortOrder])
}

model ComicScene {
  id              String       @id @default(cuid())
  name            String
  slug            String       @unique
  summary         String
  visualNotes     String
  moodNotes       String
  referenceFolder String
  referenceNotes  String?
  active          Boolean      @default(true)
  sortOrder       Int          @default(0)
  projectId       String
  project         ComicProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([projectId, sortOrder, createdAt])
  @@index([active, sortOrder])
}

model ComicSeason {
  id           String         @id @default(cuid())
  seasonNumber Int
  slug         String
  title        String
  summary      String
  outline      String
  published    Boolean        @default(false)
  sortOrder    Int            @default(0)
  projectId    String
  project      ComicProject   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  chapters     ComicChapter[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@unique([projectId, seasonNumber])
  @@unique([projectId, slug])
  @@index([published, sortOrder, createdAt])
}

model ComicChapter {
  id            String         @id @default(cuid())
  chapterNumber Int
  slug          String
  title         String
  summary       String
  outline       String
  published     Boolean        @default(false)
  sortOrder     Int            @default(0)
  seasonId      String
  season        ComicSeason    @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  episodes      ComicEpisode[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([seasonId, chapterNumber])
  @@unique([seasonId, slug])
  @@index([published, sortOrder, createdAt])
}

model ComicEpisode {
  id                        String              @id @default(cuid())
  episodeNumber             Int                 @unique
  slug                      String
  title                     String
  summary                   String
  outline                   String
  script                    String
  panelPlan                 String
  promptPack                String
  requiredReferences        String
  coverImageUrl             String?
  coverImageAlt             String?
  storyType                 String              @default("MAIN")
  extraStoryParentEpisodeId String?
  extraStoryPlacementOrder  Int                 @default(0)
  published                 Boolean             @default(false)
  publishedAt               DateTime?
  sortOrder                 Int                 @default(0)
  chapterId                 String
  chapter                   ComicChapter        @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  extraStoryParentEpisode   ComicEpisode?       @relation("ComicExtraStoryPlacement", fields: [extraStoryParentEpisodeId], references: [id], onDelete: SetNull)
  extraStories              ComicEpisode[]      @relation("ComicExtraStoryPlacement")
  assets                    ComicEpisodeAsset[]
  promptRuns                ComicPromptRun[]
  createdAt                 DateTime            @default(now())
  updatedAt                 DateTime            @updatedAt

  @@unique([chapterId, slug])
  @@index([chapterId, episodeNumber])
  @@index([storyType, published, publishedAt])
  @@index([extraStoryParentEpisodeId, extraStoryPlacementOrder, createdAt])
  @@index([published, publishedAt, sortOrder, createdAt])
}

model ComicProductLock {
  id               String    @id @default(cuid())
  productId        String    @unique
  slug             String    @unique
  displayName      String
  shortCode        String
  visualNotes      String
  usageNotes       String
  referenceNotes   String?
  imageUrl         String?
  imageData        String?
  imageMimeType    String?
  imageStorageKey  String?
  imageByteSize    Int?
  imageSha256      String?
  imagePrompt      String?
  imageGeneratedAt DateTime?
  active           Boolean   @default(true)
  sortOrder        Int       @default(0)
  product          Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([active, sortOrder, createdAt])
}

model ComicEpisodeAsset {
  id              String       @id @default(cuid())
  assetType       String       @default("PAGE")
  title           String
  imageUrl        String
  imageData       String?
  imageMimeType   String?
  imageStorageKey String?
  imageByteSize   Int?
  imageSha256     String?
  altText         String?
  caption         String?
  sortOrder       Int          @default(0)
  published       Boolean      @default(true)
  episodeId       String
  episode         ComicEpisode @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([episodeId, published, sortOrder, createdAt])
}

model ComicPromptRun {
  id                 String               @id @default(cuid())
  promptType         String
  model              String
  imageModel         String?
  status             ComicPromptRunStatus @default(DRAFT)
  inputContext       String
  outputSummary      String
  promptPack         String?
  referenceChecklist String?
  errorMessage       String?
  episodeId          String
  episode            ComicEpisode         @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  @@index([episodeId, createdAt])
  @@index([status, createdAt])
}

model ComicAiTask {
  id            String    @id @default(cuid())
  taskType      String
  label         String
  status        String    @default("QUEUED")
  payload       String
  result        String?
  errorMessage  String?
  episodeId     String?
  pageNumber    Int?
  targetId      String?
  sourceAssetId String?
  attempts      Int       @default(0)
  maxAttempts   Int       @default(2)
  lockedAt      DateTime?
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status, createdAt])
  @@index([episodeId, pageNumber, createdAt])
  @@index([taskType, targetId, status, createdAt])
  @@index([sourceAssetId, status, createdAt])
}

model ComicImageCreation {
  id                       String   @id @default(cuid())
  prompt                   String
  aspectRatio              String
  quality                  String   @default("medium")
  model                    String
  sourceType               String   @default("TEXT")
  referenceCreationId      String?
  referenceImageUrl        String?
  referenceImageData       String?
  referenceImageMimeType   String?
  referenceImageStorageKey String?
  referenceImageByteSize   Int?
  referenceImageSha256     String?
  referenceImageName       String?
  imageUrl                 String
  imageData                String?
  imageMimeType            String?
  imageStorageKey          String?
  imageByteSize            Int?
  imageSha256              String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@index([createdAt])
  @@index([referenceCreationId])
}

model Customer {
  id                           String               @id @default(cuid())
  email                        String               @unique
  firstName                    String?
  lastName                     String?
  passwordHash                 String?
  passwordSetAt                DateTime?
  lastLoginAt                  DateTime?
  marketingOptIn               Boolean              @default(false)
  loyaltyPoints                Int                  @default(0)
  totalSpentCents              Int                  @default(0)
  orders                       Order[]
  rewards                      RewardEntry[]
  mascotRedemptions            MascotRedemption[]
  ryoClaims                    RyoClaim[]
  tiktokFollowRewards          TikTokFollowReward[]
  reviews                      ProductReview[]
  sessions                     CustomerSession[]
  convertedGuestRewardSessions GuestRewardSession[] @relation("ConvertedGuestRewardSessions")
  transferredGuestRewardEvents GuestRewardEvent[]   @relation("TransferredGuestRewardEvents")
  createdAt                    DateTime             @default(now())
  updatedAt                    DateTime             @updatedAt
}

model ReviewPersona {
  id                 String          @id @default(cuid())
  slug               String          @unique
  fullName           String
  age                Int
  ageRange           String
  ethnicity          String
  occupation         String
  incomeLevel        String
  location           String
  personality        String
  bodyType           String
  skinType           String
  skinConcern        String
  lifestyle          String
  shoppingMotivation String
  priceSensitivity   String
  productPreference  String
  writingStyle       String
  reviewTone         String
  routineLevel       String
  socialChannel      String
  lifeStage          String
  tags               String
  notes              String
  lifeImagePrompt    String?
  lifeImageUrl       String?
  active             Boolean         @default(true)
  sortOrder          Int             @default(0)
  reviews            ProductReview[]
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@index([active, sortOrder, createdAt])
  @@index([ageRange])
  @@index([incomeLevel])
  @@index([ethnicity])
}

model MascotReward {
  id                    String                 @id @default(cuid())
  sku                   String                 @unique
  name                  String
  slug                  String                 @unique
  description           String?
  imageUrl              String
  pointsCost            Int                    @default(1000)
  active                Boolean                @default(true)
  sortOrder             Int                    @default(0)
  redemptions           MascotRedemption[]
  guestRedemptionDrafts GuestRedemptionDraft[]
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
}

model MascotRedemption {
  id                   String                     @id @default(cuid())
  pointsSpent          Int
  status               MascotRedemptionStatus     @default(REQUESTED)
  email                String
  fullName             String
  address1             String
  address2             String?
  city                 String
  state                String
  postalCode           String
  country              String                     @default("US")
  shippingCarrier      ShippingCarrier?
  trackingNumber       String?
  shippedAt            DateTime?
  adminNote            String?
  fulfilledAt          DateTime?
  customerId           String
  mascotId             String
  customer             Customer                   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  mascot               MascotReward               @relation(fields: [mascotId], references: [id], onDelete: Cascade)
  emailLogs            MascotRedemptionEmailLog[]
  guestRedemptionDraft GuestRedemptionDraft?      @relation("CompletedGuestRedemption")
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt

  @@index([customerId, createdAt])
  @@index([status, createdAt])
  @@index([shippingCarrier])
}

model MascotRedemptionEmailLog {
  id                String           @id @default(cuid())
  eventType         String
  recipientEmail    String
  recipientName     String?
  subject           String
  bodyText          String
  deliveryStatus    String
  deliveryProvider  String?
  deliveryMessageId String?
  errorReason       String?
  redemptionId      String
  redemption        MascotRedemption @relation(fields: [redemptionId], references: [id], onDelete: Cascade)
  createdAt         DateTime         @default(now())

  @@index([redemptionId, createdAt])
  @@index([eventType, createdAt])
  @@index([recipientEmail, createdAt])
}

model EmailContact {
  id               String            @id @default(cuid())
  email            String
  firstName        String?
  lastName         String?
  audienceType     EmailAudienceType
  source           String            @default("BREVO_IMPORT")
  brevoContactId   Int?
  brevoListId      Int?
  listName         String?
  emailBlacklisted Boolean           @default(false)
  metadata         String?
  lastSyncedAt     DateTime          @default(now())
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@unique([email, audienceType])
  @@index([audienceType, updatedAt])
  @@index([brevoListId])
}

model Order {
  id                    String             @id @default(cuid())
  orderNumber           String             @unique
  email                 String
  status                OrderStatus        @default(PENDING)
  fulfillmentStatus     FulfillmentStatus  @default(UNFULFILLED)
  currency              String             @default("USD")
  subtotalCents         Int
  discountCents         Int                @default(0)
  shippingCents         Int                @default(0)
  taxCents              Int                @default(0)
  totalCents            Int
  pointsEarned          Int                @default(0)
  couponCode            String?
  couponId              String?
  stripeCheckoutId      String?            @unique
  stripePaymentIntentId String?
  reviewToken           String?            @unique
  reviewTokenCreatedAt  DateTime?
  shippingName          String?
  shippingAddress1      String?
  shippingAddress2      String?
  shippingCity          String?
  shippingState         String?
  shippingPostalCode    String?
  shippingCountry       String?
  shippingCarrier       ShippingCarrier?
  trackingNumber        String?
  billingName           String?
  billingAddress1       String?
  billingAddress2       String?
  billingCity           String?
  billingState          String?
  billingPostalCode     String?
  billingCountry        String?
  notes                 String?
  customerId            String?
  customer              Customer?          @relation(fields: [customerId], references: [id])
  coupon                Coupon?            @relation(fields: [couponId], references: [id], onDelete: SetNull)
  items                 OrderItem[]
  shipments             OrderShipment[]
  activityLogs          OrderActivityLog[]
  emailLogs             OrderEmailLog[]
  rewards               RewardEntry[]
  reviews               ProductReview[]
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  @@index([createdAt])
  @@index([status, createdAt])
  @@index([customerId, createdAt])
}

model OrderActivityLog {
  id        String   @id @default(cuid())
  eventType String
  summary   String
  detail    String?
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([orderId, createdAt])
  @@index([eventType, createdAt])
}

model OrderShipment {
  id              String          @id @default(cuid())
  shippingCarrier ShippingCarrier
  trackingNumber  String
  sortOrder       Int             @default(0)
  orderId         String
  order           Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([orderId, sortOrder])
  @@index([shippingCarrier])
}

model OrderEmailLog {
  id                String   @id @default(cuid())
  eventType         String
  recipientEmail    String
  recipientName     String?
  subject           String
  bodyText          String
  deliveryStatus    String
  deliveryProvider  String?
  deliveryMessageId String?
  errorReason       String?
  orderId           String
  order             Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdAt         DateTime @default(now())

  @@index([orderId, createdAt])
  @@index([eventType, createdAt])
  @@index([recipientEmail, createdAt])
}

model OrderItem {
  id             String   @id @default(cuid())
  name           String
  slug           String
  quantity       Int
  unitPriceCents Int
  lineTotalCents Int
  imageUrl       String
  orderId        String
  productId      String?
  order          Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product        Product? @relation(fields: [productId], references: [id])
}

model RewardEntry {
  id         String     @id @default(cuid())
  type       RewardType
  points     Int
  note       String?
  customerId String
  orderId    String?
  customer   Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  order      Order?     @relation(fields: [orderId], references: [id])
  createdAt  DateTime   @default(now())

  @@index([customerId, createdAt])
  @@index([type, createdAt])
}

model RyoClaim {
  id                    String              @id @default(cuid())
  platformKey           String
  platformLabel         String
  orderId               String
  name                  String
  email                 String
  phone                 String?
  purchasedProduct      String?
  reviewRating          Int?
  commentText           String?
  reviewDestinationUrl  String?
  screenshotName        String?
  screenshotMimeType    String?
  screenshotBase64      String?
  screenshotBytes       Int?
  customerId            String?
  guestSessionId        String?
  pointsAwarded         Int                 @default(500)
  rewardGranted         Boolean             @default(false)
  rewardGrantedAt       DateTime?
  reviewStepSubmittedAt DateTime?
  adminNote             String?
  completedAt           DateTime?
  customer              Customer?           @relation(fields: [customerId], references: [id], onDelete: SetNull)
  guestSession          GuestRewardSession? @relation(fields: [guestSessionId], references: [id], onDelete: SetNull)
  followEmails          FollowEmailLog[]
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  @@index([platformKey, createdAt])
  @@index([email, createdAt])
  @@index([completedAt, createdAt])
  @@index([rewardGranted])
  @@index([guestSessionId, createdAt])
}

model TikTokFollowReward {
  id                 String              @id @default(cuid())
  email              String
  fullName           String
  tiktokUsername     String?
  screenshotName     String
  screenshotMimeType String
  screenshotBase64   String
  screenshotBytes    Int
  screenshotSha256   String?             @unique
  customerId         String?
  guestSessionId     String?
  pointsAwarded      Int                 @default(500)
  rewardGranted      Boolean             @default(true)
  rewardGrantedAt    DateTime            @default(now())
  customer           Customer?           @relation(fields: [customerId], references: [id], onDelete: SetNull)
  guestSession       GuestRewardSession? @relation(fields: [guestSessionId], references: [id], onDelete: SetNull)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([customerId, createdAt])
  @@index([guestSessionId, createdAt])
  @@index([rewardGranted, createdAt])
}

model GuestRewardSession {
  id                  String                   @id @default(cuid())
  tokenHash           String                   @unique
  status              GuestRewardSessionStatus @default(ACTIVE)
  emailHint           String?
  nameHint            String?
  expiresAt           DateTime
  convertedAt         DateTime?
  convertedCustomerId String?
  convertedCustomer   Customer?                @relation("ConvertedGuestRewardSessions", fields: [convertedCustomerId], references: [id], onDelete: SetNull)
  rewardEvents        GuestRewardEvent[]
  redemptionDrafts    GuestRedemptionDraft[]
  ryoClaims           RyoClaim[]
  tiktokFollowRewards TikTokFollowReward[]
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt

  @@index([status, expiresAt])
  @@index([convertedCustomerId, convertedAt])
}

model GuestRewardEvent {
  id             String                 @id @default(cuid())
  source         GuestRewardSource
  sourceId       String
  points         Int
  status         GuestRewardEventStatus @default(EARNED)
  note           String?
  guestSessionId String
  customerId     String?
  guestSession   GuestRewardSession     @relation(fields: [guestSessionId], references: [id], onDelete: Cascade)
  customer       Customer?              @relation("TransferredGuestRewardEvents", fields: [customerId], references: [id], onDelete: SetNull)
  transferredAt  DateTime?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  @@unique([source, sourceId])
  @@index([guestSessionId, status, createdAt])
  @@index([customerId, transferredAt])
}

model GuestRedemptionDraft {
  id                    String                     @id @default(cuid())
  status                GuestRedemptionDraftStatus @default(PENDING_VERIFICATION)
  email                 String
  fullName              String
  address1              String
  address2              String?
  city                  String
  state                 String
  postalCode            String
  country               String                     @default("US")
  reservedUntil         DateTime
  guestSessionId        String
  mascotId              String
  completedRedemptionId String?                    @unique
  guestSession          GuestRewardSession         @relation(fields: [guestSessionId], references: [id], onDelete: Cascade)
  mascot                MascotReward               @relation(fields: [mascotId], references: [id], onDelete: Cascade)
  completedRedemption   MascotRedemption?          @relation("CompletedGuestRedemption", fields: [completedRedemptionId], references: [id], onDelete: SetNull)
  verifications         EmailVerification[]
  completedAt           DateTime?
  createdAt             DateTime                   @default(now())
  updatedAt             DateTime                   @updatedAt

  @@index([guestSessionId, status, createdAt])
  @@index([email, status, createdAt])
  @@index([reservedUntil])
}

model EmailVerification {
  id           String                   @id @default(cuid())
  purpose      EmailVerificationPurpose
  email        String
  tokenHash    String
  expiresAt    DateTime
  attemptCount Int                      @default(0)
  consumedAt   DateTime?
  draftId      String
  draft        GuestRedemptionDraft     @relation(fields: [draftId], references: [id], onDelete: Cascade)
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt

  @@index([draftId, createdAt])
  @@index([email, purpose, createdAt])
  @@index([expiresAt])
}

model CustomerSession {
  id         String   @id @default(cuid())
  tokenHash  String   @unique
  expiresAt  DateTime
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model ProductReview {
  id                 String         @id @default(cuid())
  rating             Int
  title              String
  content            String
  displayName        String
  purchaseChannel    String?
  reviewImageUrl     String?
  hasRating          Boolean        @default(true)
  reviewDate         DateTime       @default(now())
  status             ReviewStatus   @default(PENDING)
  verifiedPurchase   Boolean        @default(false)
  incentivizedReview Boolean        @default(false)
  adminNotes         String?
  source             String         @default("CUSTOMER")
  productId          String
  customerId         String?
  orderId            String?
  personaId          String?
  publishedAt        DateTime?
  product            Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  customer           Customer?      @relation(fields: [customerId], references: [id], onDelete: SetNull)
  order              Order?         @relation(fields: [orderId], references: [id], onDelete: SetNull)
  persona            ReviewPersona? @relation(fields: [personaId], references: [id], onDelete: SetNull)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@unique([orderId, productId])
  @@index([productId, reviewDate])
  @@index([productId, status, reviewDate])
  @@index([customerId, reviewDate])
  @@index([personaId, reviewDate])
  @@index([status, reviewDate])
}

model StoreSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  createdAt DateTime @default(now())
}

model Coupon {
  id             String             @id @default(cuid())
  code           String             @unique
  content        String
  active         Boolean            @default(true)
  combinable     Boolean            @default(false)
  appliesToAll   Boolean            @default(false)
  productCodes   String?
  discountType   CouponDiscountType
  percentOff     Int?
  amountOffCents Int?
  usageMode      CouponUsageMode    @default(UNLIMITED)
  usageCount     Int                @default(0)
  expiresAt      DateTime?
  orders         Order[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([active, expiresAt])
}

model FormSubmission {
  id                        String    @id @default(cuid())
  formKey                   String
  formLabel                 String
  email                     String
  name                      String?
  subject                   String?
  summary                   String?
  message                   String?
  payload                   String?
  handled                   Boolean   @default(false)
  handledAt                 DateTime?
  legacyContactSubmissionId String?   @unique
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  @@index([formKey, createdAt])
  @@index([formKey, handled, createdAt])
  @@index([formKey, email, createdAt])
  @@index([email])
  @@index([handled])
}

model EmailCampaign {
  id              String              @id @default(cuid())
  name            String
  subject         String
  previewText     String?
  strategyBrief   String?
  audienceType    EmailAudienceType   @default(NEWSLETTER)
  customListIds   String?
  senderName      String?
  senderEmail     String?
  replyTo         String?
  contentHtml     String
  contentText     String?
  scheduledAt     DateTime?
  status          EmailCampaignStatus @default(DRAFT)
  brevoCampaignId Int?
  lastSyncedAt    DateTime?
  lastTestedAt    DateTime?
  lastSentAt      DateTime?
  syncError       String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([status, updatedAt])
  @@index([audienceType])
  @@index([scheduledAt])
}

model OmbClaim {
  id                    String           @id @default(cuid())
  platformKey           String
  platformLabel         String
  orderId               String
  name                  String
  email                 String
  phone                 String?
  purchasedProduct      String?
  reviewRating          Int?
  commentText           String?
  reviewDestinationUrl  String?
  screenshotName        String?
  screenshotMimeType    String?
  screenshotBase64      String?
  screenshotBytes       Int?
  extraBottleAddress    String?
  giftSent              Boolean          @default(false)
  giftSentAt            DateTime?
  reviewStepSubmittedAt DateTime?
  adminNote             String?
  completedAt           DateTime?
  followEmails          FollowEmailLog[]
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  @@index([platformKey, createdAt])
  @@index([email, createdAt])
  @@index([platformKey, purchasedProduct, createdAt])
  @@index([giftSent])
  @@index([completedAt, createdAt])
}

model FollowEmailLog {
  id             String             @id @default(cuid())
  processKey     FollowEmailProcess
  stageKey       FollowEmailStage
  recipientEmail String
  recipientName  String?
  subject        String
  bodyText       String
  ombClaimId     String?
  ryoClaimId     String?
  ombClaim       OmbClaim?          @relation(fields: [ombClaimId], references: [id], onDelete: Cascade)
  ryoClaim       RyoClaim?          @relation(fields: [ryoClaimId], references: [id], onDelete: Cascade)
  createdAt      DateTime           @default(now())

  @@unique([ombClaimId, stageKey])
  @@unique([ryoClaimId, stageKey])
  @@index([processKey, createdAt])
  @@index([stageKey, createdAt])
}

model MailboxReplyExample {
  id                String   @id @default(cuid())
  toEmail           String
  subject           String
  bodyText          String
  replyTo           String?
  sourceSenderName  String?
  sourceSenderEmail String?
  sourceSubject     String?
  sourceSnippet     String?
  createdAt         DateTime @default(now())

  @@index([toEmail, createdAt])
  @@index([createdAt])
}

model FinancePaymentDetail {
  id                   String   @id @default(cuid())
  paymentDate          DateTime @default(now())
  paymentStage         String   @default("预付款")
  accountType          String   @default("公账")
  lingxingContractNo   String?
  sku                  String
  productName          String
  unit                 String   @default("瓶")
  quantity             Decimal  @default(0) @db.Decimal(18, 4)
  unitPriceYuan        Decimal  @default(0) @db.Decimal(18, 4)
  totalAmountYuan      Decimal  @default(0) @db.Decimal(18, 2)
  paymentAmountYuan    Decimal  @default(0) @db.Decimal(18, 2)
  sourceFileName       String?
  paymentProofName     String?
  paymentProofMimeType String?
  paymentProofBase64   String?
  paymentProofBytes    Int?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([paymentDate])
  @@index([paymentStage, paymentDate])
  @@index([accountType, paymentDate])
  @@index([lingxingContractNo])
  @@index([sku])
}
